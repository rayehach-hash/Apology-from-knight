<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>The Queen's Letter</title>

<link href="https://fonts.googleapis.com/css2?family=Cinzel&family=Great+Vibes&family=Dancing+Script:wght@500&display=swap" rel="stylesheet">

<style>

body{
background:radial-gradient(circle,#5a0000,#1a0000);
display:flex;
justify-content:center;
align-items:center;
height:100vh;
margin:0;
font-family:'Cinzel',serif;
}

.letter{
width:650px;
height:620px;
background:#f6ecd2;
border:12px solid #d2b48c;
box-shadow:0 20px 60px rgba(0,0,0,0.8);
padding:40px;
display:none;
flex-direction:column;
justify-content:center;
text-align:center;
background-image:url("https://www.transparenttextures.com/patterns/aged-paper.png");
}

.active{
display:flex;
}

h1{
font-family:'Great Vibes',cursive;
font-size:52px;
color:#3b2a1a;
margin-top:0;
}

p{
font-family:'Dancing Script',cursive;
font-size:28px;
line-height:1.8;
color:#3b2a1a;
}

button{
background:#5a0f0f;
color:white;
border:none;
padding:12px 26px;
margin:12px;
font-size:18px;
cursor:pointer;
border-radius:5px;
}

button:hover{
background:#7a1515;
}

#result{
font-family:'Great Vibes',cursive;
font-size:32px;
margin-top:20px;
color:#5a0f0f;
}

</style>
</head>

<body>

<!-- PAGE 1 -->
<div id="page1" class="letter active">

<h1>A Royal Letter</h1>

<p id="intro"></p>

<button onclick="nextPage()">I will listen</button>
<button onclick="nextPage()">Speak, my Queen</button>

</div>


<!-- PAGE 2 -->
<div id="page2" class="letter">

<h1>The Apology</h1>

<p id="letterText"></p>

<button onclick="finalPage()">Continue</button>

</div>


<!-- PAGE 3 -->
<div id="page3" class="letter">

<h1>The Final Question</h1>

<p>
My Knight…<br><br>
Can your heart forgive your Queen?
</p>

<button onclick="forgive()">Forgive</button>
<button id="noBtn">No</button>

<div id="result"></div>

</div>


<script>

const introMessage =
`My dear Knight,

Before you read the words written upon this parchment,
I must ask something of you.

Will you listen to the heart of your Queen?`;

const apologyMessage =
`My Knight,

I write these words with a humble heart.

Earlier, my words were harsher than they should have been.
And though the moment has passed,
the thought of hurting you still troubles me.

The truth is simple —
I wished to see you,
and my emotions betrayed me.

You deserved patience and kindness,
yet I gave you frustration.

For that I am deeply sorry.

If your heart still holds kindness for your Queen,
I hope you may forgive me.`;


let i = 0;
let j = 0;

function typeIntro(){
if(i < introMessage.length){
document.getElementById("intro").innerHTML += introMessage.charAt(i);
i++;
setTimeout(typeIntro,30);
}
}

function typeLetter(){
if(j < apologyMessage.length){
document.getElementById("letterText").innerHTML += apologyMessage.charAt(j);
j++;
setTimeout(typeLetter,30);
}
}

typeIntro();

function nextPage(){
document.getElementById("page1").classList.remove("active");
document.getElementById("page2").classList.add("active");
typeLetter();
}

function finalPage(){
document.getElementById("page2").classList.remove("active");
document.getElementById("page3").classList.add("active");
}

function forgive(){
document.getElementById("result").innerHTML="Your Queen thanks you with all her heart ❤️";
}

const noBtn = document.getElementById("noBtn");

noBtn.addEventListener("mouseover", function(){
const x = Math.random()*400 - 200;
const y = Math.random()*200 - 100;
noBtn.style.transform=`translate(${x}px,${y}px)`;
});

</script>

</body>
</html>
